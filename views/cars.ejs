<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> | Car Rental</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="topbar">
    <div class="brand">
      <h1>Quản lý xe</h1>
      <p>Danh sách xe &amp; thông tin vận hành</p>
    </div>
    <nav>
      <a href="/">Dashboard</a>
      <a href="/cars" class="active">Cars</a>
      <a href="/bookings">Bookings</a>
      <a href="/users">Users</a>
    </nav>
  </header>

  <main class="container two-columns">
    <section class="card">
      <h2>Thêm xe mới</h2>
      <% if (error) { %>
        <p class="alert error"><%= error %></p>
      <% } %>
      <% if (success) { %>
        <p class="alert success"><%= success %></p>
      <% } %>
      <form action="/cars" method="POST" class="form-grid">
        <label>Biển số (VD: 30A-123.45)
          <input type="text" name="carNumber" pattern="^(?:[1-9]\\d)[A-Z]-\\d{3}\\.\\d{2}$" title="Định dạng: 30A-123.45" required />
        </label>
        <label>Số chỗ (2, 5, 7)
          <select name="capacity" required>
            <option value="2">2</option>
            <option value="5">5</option>
            <option value="7">7</option>
          </select>
        </label>
        <label>Trạng thái
          <select name="status" required>
            <option value="available">available</option>
            <option value="rented">rented</option>
            <option value="maintenance">maintenance</option>
          </select>
        </label>
        <label>Giá/ngày
          <input type="number" name="pricePerDay" min="1" required />
        </label>
        <label class="full">Tiện ích (cách nhau bằng dấu phẩy)
          <input type="text" name="features" placeholder="GPS, Camera, Bluetooth" />
        </label>
        <button type="submit" class="btn full">Tạo xe</button>
      </form>
    </section>

    <section class="card">
      <h2>Bộ lọc</h2>
      <form method="GET" action="/cars" class="form-grid">
        <label>Biển số
          <input type="text" name="q" value="<%= filters.q %>" placeholder="Tìm biển số" />
        </label>
        <label>Trạng thái
          <select name="status">
            <option value="">Tất cả</option>
            <option value="available" <%= filters.status === 'available' ? 'selected' : '' %>>available</option>
            <option value="rented" <%= filters.status === 'rented' ? 'selected' : '' %>>rented</option>
            <option value="maintenance" <%= filters.status === 'maintenance' ? 'selected' : '' %>>maintenance</option>
          </select>
        </label>
        <button type="submit" class="btn">Lọc</button>
      </form>
    </section>

    <section class="card full-width">
      <h2>Danh sách xe</h2>
      <div class="car-grid">
        <% if (!cars.length) { %>
          <p class="center">Không có dữ liệu xe</p>
        <% } %>
        <% const carImages = [
          "https://images.unsplash.com/photo-1493238792000-8113da705763?auto=format&fit=crop&w=900&q=80",
          "https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&w=900&q=80",
          "https://images.unsplash.com/photo-1502877338535-766e1452684a?auto=format&fit=crop&w=900&q=80",
          "https://images.unsplash.com/photo-1511919884226-fd3cad34687c?auto=format&fit=crop&w=900&q=80"
        ]; %>
        <% cars.forEach((car, index) => { %>
          <div class="car-card">
            <img src="<%= carImages[index % carImages.length] %>" alt="<%= car.carNumber %>" />
            <div class="content">
              <h4><%= car.carNumber %></h4>
              <p class="muted">Số chỗ: <strong><%= car.capacity %></strong></p>
              <p class="muted">Giá/ngày: <strong><%= car.pricePerDay.toLocaleString('vi-VN') %> ₫</strong></p>
              <p class="muted">Trạng thái: <span class="badge <%= car.status %>"><%= car.status %></span></p>
              <p class="muted">Tiện ích: <%= (car.features || []).join(', ') || 'Chưa cập nhật' %></p>
              <details>
                <summary>Sửa nhanh</summary>
                <form action="/cars/<%= car.carNumber %>/update" method="POST" class="inline-form">
                  <input type="number" name="capacity" min="1" value="<%= car.capacity %>" required />
                  <select name="status" required>
                    <option value="available" <%= car.status === 'available' ? 'selected' : '' %>>available</option>
                    <option value="rented" <%= car.status === 'rented' ? 'selected' : '' %>>rented</option>
                    <option value="maintenance" <%= car.status === 'maintenance' ? 'selected' : '' %>>maintenance</option>
                  </select>
                  <input type="number" name="pricePerDay" min="0" value="<%= car.pricePerDay %>" required />
                  <input type="text" name="features" value="<%= (car.features || []).join(', ') %>" />
                  <button type="submit" class="btn small">Lưu</button>
                </form>
              </details>
              <form action="/cars/<%= car.carNumber %>/delete" method="POST" onsubmit="return confirm('Xoá xe này?');">
                <button class="btn danger small" type="submit">Xoá</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
  </main>
</body>
</html>
