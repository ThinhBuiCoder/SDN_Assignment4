<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> | Car Rental</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="topbar">
    <h1>Quản lý xe</h1>
    <nav>
      <a href="/">Dashboard</a>
      <a href="/cars" class="active">Cars</a>
      <a href="/bookings">Bookings</a>
    </nav>
  </header>

  <main class="container two-columns">
    <section class="card">
      <h2>Thêm xe mới</h2>
      <% if (error) { %>
        <p class="alert error"><%= error %></p>
      <% } %>
      <% if (success) { %>
        <p class="alert success"><%= success %></p>
      <% } %>
      <form action="/cars" method="POST" class="form-grid">
        <label>Biển số
          <input type="text" name="carNumber" required />
        </label>
        <label>Số chỗ
          <input type="number" name="capacity" min="1" required />
        </label>
        <label>Trạng thái
          <select name="status" required>
            <option value="available">available</option>
            <option value="rented">rented</option>
            <option value="maintenance">maintenance</option>
          </select>
        </label>
        <label>Giá/ngày
          <input type="number" name="pricePerDay" min="0" required />
        </label>
        <label class="full">Tiện ích (cách nhau bằng dấu phẩy)
          <input type="text" name="features" placeholder="GPS, Camera, Bluetooth" />
        </label>
        <button type="submit" class="btn full">Tạo xe</button>
      </form>
    </section>

    <section class="card">
      <h2>Bộ lọc</h2>
      <form method="GET" action="/cars" class="form-grid">
        <label>Biển số
          <input type="text" name="q" value="<%= filters.q %>" placeholder="Tìm biển số" />
        </label>
        <label>Trạng thái
          <select name="status">
            <option value="">Tất cả</option>
            <option value="available" <%= filters.status === 'available' ? 'selected' : '' %>>available</option>
            <option value="rented" <%= filters.status === 'rented' ? 'selected' : '' %>>rented</option>
            <option value="maintenance" <%= filters.status === 'maintenance' ? 'selected' : '' %>>maintenance</option>
          </select>
        </label>
        <button type="submit" class="btn">Lọc</button>
      </form>
    </section>

    <section class="card full-width">
      <h2>Danh sách xe</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Biển số</th>
              <th>Số chỗ</th>
              <th>Trạng thái</th>
              <th>Giá/ngày</th>
              <th>Tiện ích</th>
              <th>Hành động</th>
            </tr>
          </thead>
          <tbody>
            <% if (!cars.length) { %>
              <tr>
                <td colspan="6" class="center">Không có dữ liệu xe</td>
              </tr>
            <% } %>
            <% cars.forEach(car => { %>
              <tr>
                <td><%= car.carNumber %></td>
                <td><%= car.capacity %></td>
                <td>
                  <span class="badge <%= car.status %>"><%= car.status %></span>
                </td>
                <td><%= car.pricePerDay %></td>
                <td><%= (car.features || []).join(', ') %></td>
                <td>
                  <details>
                    <summary>Sửa</summary>
                    <form action="/cars/<%= car.carNumber %>/update" method="POST" class="inline-form">
                      <input type="number" name="capacity" min="1" value="<%= car.capacity %>" required />
                      <select name="status" required>
                        <option value="available" <%= car.status === 'available' ? 'selected' : '' %>>available</option>
                        <option value="rented" <%= car.status === 'rented' ? 'selected' : '' %>>rented</option>
                        <option value="maintenance" <%= car.status === 'maintenance' ? 'selected' : '' %>>maintenance</option>
                      </select>
                      <input type="number" name="pricePerDay" min="0" value="<%= car.pricePerDay %>" required />
                      <input type="text" name="features" value="<%= (car.features || []).join(', ') %>" />
                      <button type="submit" class="btn small">Lưu</button>
                    </form>
                  </details>
                  <form action="/cars/<%= car.carNumber %>/delete" method="POST" onsubmit="return confirm('Xoá xe này?');">
                    <button class="btn danger small" type="submit">Xoá</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>
</html>
