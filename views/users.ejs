<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> | Car Rental</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="topbar">
    <div class="brand">
      <h1>Quản lý tài khoản</h1>
      <p>Khoá/mở tài khoản và phân quyền</p>
    </div>
    <nav>
      <a href="/">Dashboard</a>
      <a href="/cars">Cars</a>
      <a href="/bookings">Bookings</a>
      <a href="/users" class="active">Users</a>
    </nav>
  </header>

  <main class="container">
    <section class="card">
      <h2>Danh sách tài khoản</h2>
      <% if (error) { %>
        <p class="alert error"><%= error %></p>
      <% } %>
      <% if (success) { %>
        <p class="alert success"><%= success %></p>
      <% } %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Tài khoản</th>
              <th>Vai trò</th>
              <th>Trạng thái</th>
              <th>Ngày tạo</th>
              <th>Hành động</th>
            </tr>
          </thead>
          <tbody>
            <% if (!users.length) { %>
              <tr>
                <td colspan="5" class="center">Không có tài khoản</td>
              </tr>
            <% } %>
            <% users.forEach(user => { %>
              <tr>
                <td><%= user.username %></td>
                <td><span class="badge <%= user.role === 'admin' ? 'available' : 'maintenance' %>"><%= user.role %></span></td>
                <td>
                  <span class="status <%= user.isActive ? 'active' : 'locked' %>">
                    <%= user.isActive ? 'Đang hoạt động' : 'Đã khóa' %>
                  </span>
                </td>
                <td><%= new Date(user.createdAt).toLocaleDateString('vi-VN') %></td>
                <td>
                  <form action="/users/<%= user._id %>/toggle" method="POST" onsubmit="return confirm('Thay đổi trạng thái tài khoản?');">
                    <button class="btn <%= user.isActive ? 'danger' : '' %> small" type="submit">
                      <%= user.isActive ? 'Khóa' : 'Mở' %>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>
</html>
